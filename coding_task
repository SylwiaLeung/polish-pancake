import unittest
from collections import Counter


#this function checks if the given number is prime
def is_prime(value):
    if value <= 1:
        return False
    for number in range(2, value):
        if value % number == 0:
            return False
    return True
    
    
#this function creates a dictionary with items found in both sequences, checks values from seq2 for primality
#then creates a new list based on the sequence1, with elements from the dictionary only
def seq_difference(sequence_one, sequence_two):
    seq_one = Counter(sequence_one)
    seq_two = Counter(sequence_two)
    shared_items = {key: seq_one[key] for key in seq_one if not is_prime(seq_two[key])}
    seq_three = [element for element in sequence_one if element in shared_items]
    return seq_three


#this is a testing class for primality
class TestIsPrime(unittest.TestCase):
    def test_prime(self):
        self.assertTrue(is_prime(2))

    def test_prime1(self):
        self.assertTrue(is_prime(1))

    def test_prime2(self):
        self.assertTrue(is_prime(3))
